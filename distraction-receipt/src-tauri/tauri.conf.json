{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Distraction Receipt",
  "version": "0.1.0",
  "identifier": "com.jannawrot.distraction-receipt",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Distraction Receipt",
        "width": 290,
        "height": 500,
        "minWidth": 260,
        "minHeight": 420,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": false,
        "visible": true,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:1420; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;"
    },
    "macOSPrivateApi": true,
    "trayIcon": {
      "id": "tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Distraction Receipt"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "entitlements": "./Entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  }
}
